{
  "cli": {
    "version": ">= 16.17.4",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "ios": {
        "resourceClass": "m-medium"
      }
    },
    "production": {
      "environment": "production",
      "ios": {
        "buildConfiguration": "Release",
        "distribution": "store",
        "autoIncrement": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_NO_CAPABILITY_SYNC": "1"
      }
    },
    "production-adhoc": {
      "environment": "production",
      "ios": {
        "buildConfiguration": "Release",
        "distribution": "internal",
        "autoIncrement": true,
        "resourceClass": "m-medium"
      }
    },
    "simulator": {
      "environment": "development",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6738792875",
        "appleTeamId": "64HC4N3958"
      }
    }
  }
}
